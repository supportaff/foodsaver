# Database - PostgreSQL connection string
# Get a free DB from: https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# NextAuth - Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"  # In production: https://your-app.vercel.app

# Google Maps API Key (optional for MVP)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Email (optional - for notifications)
# SMTP settings for nodemailer
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="FoodSaver <noreply@foodsaver.app>"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
